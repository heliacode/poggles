[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/pause_menu.gd" id="1"]
[ext_resource type="FontFile" path="res://assets/ui/KenneyFuture.ttf" id="2_font"]

[node name="PauseMenu" type="CanvasLayer"]
layer = 90
script = ExtResource("1")

[node name="Panel" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.7)

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -120.0
offset_top = -180.0
offset_right = 120.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.3, 0.85, 1.0, 1)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 32
text = "PAUSED"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 8)

[node name="ResumeBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_colors/font_color = Color(0.3, 1.0, 0.5, 1)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 18
text = "RESUME"

[node name="RestartBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_colors/font_color = Color(0.3, 0.85, 1.0, 1)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 18
text = "RESTART BOARD"

[node name="SettingsBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_colors/font_color = Color(0.5, 0.8, 1.0, 0.8)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 18
text = "SETTINGS"

[node name="AbandonBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_colors/font_color = Color(1.0, 0.4, 0.3, 0.9)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 18
text = "ABANDON RUN"

[node name="LevelSelectBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_colors/font_color = Color(0.5, 0.8, 1.0, 0.8)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 18
text = "LEVEL SELECT"

[node name="MainMenuBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_colors/font_color = Color(0.5, 0.8, 1.0, 0.8)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 18
text = "MAIN MENU"

[connection signal="pressed" from="Panel/VBox/ResumeBtn" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="Panel/VBox/RestartBtn" to="." method="_on_restart_pressed"]
[connection signal="pressed" from="Panel/VBox/SettingsBtn" to="." method="_on_settings_pressed"]
[connection signal="pressed" from="Panel/VBox/AbandonBtn" to="." method="_on_abandon_pressed"]
[connection signal="pressed" from="Panel/VBox/LevelSelectBtn" to="." method="_on_level_select_pressed"]
[connection signal="pressed" from="Panel/VBox/MainMenuBtn" to="." method="_on_main_menu_pressed"]
