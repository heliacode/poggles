[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/results_screen.gd" id="1"]
[ext_resource type="Script" path="res://scripts/background.gd" id="2_bg"]
[ext_resource type="FontFile" path="res://assets/ui/KenneyFuture.ttf" id="3_font"]

[node name="Results" type="Node2D"]
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
offset_right = 1280.0
offset_bottom = 720.0
color = Color(0.01, 0.01, 0.03, 1)
script = ExtResource("2_bg")

[node name="UI" type="CanvasLayer" parent="."]

[node name="HBox" type="HBoxContainer" parent="UI"]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -250.0
offset_top = -100.0
offset_right = 250.0
offset_bottom = -40.0
grow_horizontal = 2
grow_vertical = 0
theme_override_constants/separation = 20
alignment = 1

[node name="RetryBtn" type="Button" parent="UI/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(140, 50)
theme_override_colors/font_color = Color(1.0, 0.4, 0.1, 1)
theme_override_fonts/font = ExtResource("3_font")
theme_override_font_sizes/font_size = 18
text = "RETRY"

[node name="MenuBtn" type="Button" parent="UI/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(140, 50)
theme_override_colors/font_color = Color(0.5, 0.8, 1.0, 0.8)
theme_override_fonts/font = ExtResource("3_font")
theme_override_font_sizes/font_size = 18
text = "LEVELS"

[node name="NextBtn" type="Button" parent="UI/HBox"]
layout_mode = 2
custom_minimum_size = Vector2(140, 50)
theme_override_colors/font_color = Color(0.3, 1.0, 0.5, 1)
theme_override_fonts/font = ExtResource("3_font")
theme_override_font_sizes/font_size = 18
text = "NEXT"

[connection signal="pressed" from="UI/HBox/RetryBtn" to="." method="_on_retry_pressed"]
[connection signal="pressed" from="UI/HBox/MenuBtn" to="." method="_on_menu_pressed"]
[connection signal="pressed" from="UI/HBox/NextBtn" to="." method="_on_next_pressed"]
