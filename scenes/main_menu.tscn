[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/main_menu.gd" id="1"]
[ext_resource type="Script" path="res://scripts/background.gd" id="2_bg"]
[ext_resource type="FontFile" path="res://assets/ui/KenneyFuture.ttf" id="3_font"]

[node name="MainMenu" type="Node2D"]
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
offset_right = 1280.0
offset_bottom = 720.0
color = Color(0.01, 0.01, 0.03, 1)
script = ExtResource("2_bg")

[node name="UI" type="CanvasLayer" parent="."]

[node name="VBox" type="VBoxContainer" parent="UI"]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -110.0
offset_top = 20.0
offset_right = 110.0
offset_bottom = 300.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 16

[node name="NewRunBtn" type="Button" parent="UI/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(220, 50)
theme_override_colors/font_color = Color(0.3, 1.0, 0.5, 1)
theme_override_fonts/font = ExtResource("3_font")
theme_override_font_sizes/font_size = 22
text = "NEW RUN"

[node name="PracticeBtn" type="Button" parent="UI/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(220, 45)
theme_override_colors/font_color = Color(0.3, 0.85, 1.0, 1)
theme_override_fonts/font = ExtResource("3_font")
theme_override_font_sizes/font_size = 18
text = "PRACTICE"

[node name="SettingsBtn" type="Button" parent="UI/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(220, 45)
theme_override_colors/font_color = Color(0.5, 0.7, 0.9, 0.8)
theme_override_fonts/font = ExtResource("3_font")
theme_override_font_sizes/font_size = 18
text = "SETTINGS"

[node name="QuitBtn" type="Button" parent="UI/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(220, 45)
theme_override_colors/font_color = Color(0.5, 0.5, 0.6, 0.6)
theme_override_fonts/font = ExtResource("3_font")
theme_override_font_sizes/font_size = 18
text = "QUIT"

[connection signal="pressed" from="UI/VBox/NewRunBtn" to="." method="_on_new_run_pressed"]
[connection signal="pressed" from="UI/VBox/PracticeBtn" to="." method="_on_practice_pressed"]
[connection signal="pressed" from="UI/VBox/SettingsBtn" to="." method="_on_settings_pressed"]
[connection signal="pressed" from="UI/VBox/QuitBtn" to="." method="_on_quit_pressed"]
